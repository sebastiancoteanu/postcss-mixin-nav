{
  "name": "postcss-mixin-nav",
  "displayName": "PostCSS Mixin Navigator",
  "description": "Go-to-definition for postcss-mixins (@define-mixin / @mixin)",
  "version": "0.1.4",
  "publisher": "SebastianCoteanu",
  "license": "MIT",
  "icon": "images/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sebastiancoteanu/postcss-mixin-nav.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:css",
    "onLanguage:postcss",
    "onLanguage:scss",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "semanticTokenTypes": [
      {
        "id": "type",
        "description": "PostCSS mixin name — colored like a class/type in the active theme"
      }
    ],
    "configuration": {
      "title": "PostCSS Mixin Navigator",
      "properties": {
        "postcssMixinNav.fileGlob": {
          "type": "string",
          "default": "**/*.{css,pcss,postcss}",
          "description": "Glob pattern for files to search for @define-mixin definitions"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
